---
/**
 * CTA — Call-to-Action final
 * Glass card com glow verde
 */
---

<section class="cta-section" id="contato">
  <div class="cta-section__container">
    <div class="cta-section__card glass-accent reveal">
      <!-- Glow de fundo -->
      <div class="cta-section__glow" aria-hidden="true"></div>

      <h2 class="cta-section__title">O fim do improviso em planilhas</h2>
      <p class="cta-section__description">
        Estruture a evolução do ensino adotando modernidade instantânea e ganho técnico administrativo.
      </p>

      <div class="cta-section__actions">
        <a href="#" class="btn btn-primary btn-large" id="cta-final">
          Acessar GeAD
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    padding: 5rem 0 7rem;
  }

  .cta-section__container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .cta-section__card {
    position: relative;
    text-align: center;
    padding: 4rem 3rem;
    border-radius: 24px;
    overflow: hidden;
  }

  .cta-section__glow {
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(10, 166, 49, 0.2) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
    filter: blur(40px);
  }

  .cta-section__title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: 1.25rem;
    letter-spacing: -1px;
    position: relative;
    z-index: 2;
  }

  .cta-section__description {
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 550px;
    margin-left: auto;
    margin-right: auto;
    position: relative;
    z-index: 2;
  }

  .cta-section__actions {
    position: relative;
    z-index: 2;
  }

  @media (max-width: 768px) {
    .cta-section {
      padding: 3rem 0 4rem;
    }

    .cta-section__card {
      padding: 3rem 1.5rem;
    }
  }
</style>
