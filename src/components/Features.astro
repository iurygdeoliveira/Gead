---
/**
 * Features — Bento grid com funcionalidades do GeAD
 * Glass cards com ícones SVG
 */
---

<section class="features" id="funcionalidades">
  <div class="features__container">
    <div class="features__grid">

      <!-- Feature 1: SUAP (Destaque largo) -->
      <div class="features__item features__item--large glass reveal">
        <div class="features__content">
          <div class="features__icon features__icon--green" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
            </svg>
          </div>
          <h3 class="features__title">Integração SUAP Direta</h3>
          <p class="features__desc">Autenticação via matrícula que cruza imediatamente situação de discentes matriculados vs evadidos antes do voto ser computado.</p>
        </div>

        <!-- Mini tabela visual -->
        <div class="features__visual">
          <div class="features__table">
            <div class="features__table-row features__table-row--header">
              <span>Matrícula</span>
              <span>Status</span>
            </div>
            <div class="features__table-row">
              <span class="features__table-code">2024101A...</span>
              <span class="features__status features__status--active">Ativo</span>
            </div>
            <div class="features__table-row">
              <span class="features__table-code">2023201R...</span>
              <span class="features__status features__status--blocked">Evasão</span>
            </div>
            <div class="features__table-row">
              <span class="features__table-code">2024305B...</span>
              <span class="features__status features__status--active">Ativo</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature 2: Relatórios PDF -->
      <div class="features__item glass reveal" style="transition-delay: 100ms;">
        <div class="features__content">
          <div class="features__icon features__icon--green" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
          </div>
          <h3 class="features__title">Relatórios Consolidados</h3>
          <p class="features__desc">Distribuição autônoma de PDFs para a caixa de e-mail de cada educador avaliado ao fim da janela institucional.</p>
        </div>
      </div>

      <!-- Feature 3: GOV.BR -->
      <div class="features__item glass reveal" style="transition-delay: 200ms;">
        <div class="features__content">
          <div class="features__icon features__icon--green" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              <path d="m9 12 2 2 4-4"></path>
            </svg>
          </div>
          <h3 class="features__title">Certificação GOV.BR</h3>
          <p class="features__desc">Workflow sem contestação e completamente auditável graças à assinatura oficial eletrônica no fim do processo.</p>
        </div>
      </div>

      <!-- Feature 4: Dashboard (Destaque largo) -->
      <div class="features__item features__item--wide glass reveal" style="transition-delay: 150ms;">
        <div class="features__content features__content--horizontal">
          <div class="features__info">
            <div class="features__icon features__icon--green" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7"></rect>
                <rect x="14" y="3" width="7" height="7"></rect>
                <rect x="14" y="14" width="7" height="7"></rect>
                <rect x="3" y="14" width="7" height="7"></rect>
              </svg>
            </div>
            <h3 class="features__title">Dashboard Gerencial Restrito</h3>
            <p class="features__desc">Gerência enxerga o painel ampliado e controle de semestres; docente vê seus resultados sem distração; discente submete o questionário blindado contra repetência indesejada.</p>
          </div>

          <!-- Mini visual de roles -->
          <div class="features__roles" aria-hidden="true">
            <div class="features__role glass">
              <div class="features__role-dot features__role-dot--primary"></div>
              <span>Gerência</span>
            </div>
            <div class="features__role glass">
              <div class="features__role-dot features__role-dot--highlight"></div>
              <span>Docente</span>
            </div>
            <div class="features__role glass">
              <div class="features__role-dot features__role-dot--muted"></div>
              <span>Discente</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .features {
    position: relative;
    padding: 2rem 0 7rem;
  }

  .features__container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: minmax(280px, auto);
    gap: 1.25rem;
  }

  .features__item {
    border-radius: 20px;
    padding: 2.25rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .features__item:hover {
    border-color: var(--color-border-accent) !important;
    box-shadow: var(--shadow-glow);
    transform: translateY(-4px);
  }

  .features__item--large {
    grid-column: span 1;
    grid-row: span 2;
  }

  .features__item--wide {
    grid-column: span 3;
    grid-row: span 1;
  }

  .features__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    z-index: 2;
  }

  .features__content--horizontal {
    flex-direction: row;
    align-items: center;
    gap: 3rem;
  }

  .features__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 14px;
    margin-bottom: 1.5rem;
    flex-shrink: 0;
  }

  .features__icon--green {
    background: rgba(10, 166, 49, 0.1);
    color: var(--color-highlight);
    border: 1px solid rgba(10, 166, 49, 0.15);
  }

  .features__title {
    font-size: 1.2rem;
    margin-bottom: 0.875rem;
    letter-spacing: -0.5px;
  }

  .features__desc {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  /* === Mini tabela visual === */
  .features__visual {
    margin-top: auto;
    padding-top: 1.5rem;
  }

  .features__table {
    border: 1px solid var(--color-border-glass);
    border-radius: 10px;
    overflow: hidden;
    font-size: 0.8rem;
  }

  .features__table-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.625rem 1rem;
    border-bottom: 1px solid var(--color-border-glass);
  }

  .features__table-row:last-child {
    border-bottom: none;
  }

  .features__table-row--header {
    background: rgba(255, 255, 255, 0.03);
    color: var(--color-text-muted);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .features__table-code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: var(--color-text-secondary);
    font-size: 0.78rem;
  }

  .features__status {
    padding: 2px 10px;
    border-radius: 100px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .features__status--active {
    background: rgba(10, 166, 49, 0.15);
    color: var(--color-highlight);
    border: 1px solid rgba(10, 166, 49, 0.2);
  }

  .features__status--blocked {
    background: rgba(191, 4, 4, 0.12);
    color: #ef4444;
    border: 1px solid rgba(191, 4, 4, 0.2);
  }

  /* === Roles badges === */
  .features__roles {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .features__role {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    border-radius: 10px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .features__role-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .features__role-dot--primary { background: var(--color-highlight); box-shadow: 0 0 8px rgba(10, 166, 49, 0.5); }
  .features__role-dot--highlight { background: #38bdf8; box-shadow: 0 0 8px rgba(56, 189, 248, 0.5); }
  .features__role-dot--muted { background: var(--color-text-muted); }

  /* === Responsivo === */
  @media (max-width: 1024px) {
    .features__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .features__item--wide {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .features__grid {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
      gap: 1rem;
    }

    .features__item--large,
    .features__item--wide {
      grid-column: span 1;
      grid-row: span 1;
    }

    .features__content--horizontal {
      flex-direction: column;
      gap: 1.5rem;
      text-align: center;
    }

    .features__roles {
      flex-wrap: wrap;
      justify-content: center;
    }

    .features__item {
      padding: 1.75rem;
    }

    .features {
      padding: 2rem 0 4rem;
    }
  }
</style>
