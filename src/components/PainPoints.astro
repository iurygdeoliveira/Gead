---
/**
 * PainPoints — Seção "Dores" do processo atual
 * Cards glass com bordas vermelhas sutis
 */

const painPoints = [
  {
    title: 'Retrabalho Exaustivo',
    description: 'O esforço de mapear cada avaliação docente em planilhas dispersas paralisa a gerência todo fim de semestre.',
    icon: 'alert-triangle',
  },
  {
    title: 'Vulnerabilidade de Dados',
    description: 'Falta de mecanismo antifraude institucional. Alunos evadidos conseguem forjar avaliações distorcendo o panorama docente real.',
    icon: 'lock',
  },
  {
    title: 'Distribuição Manual',
    description: 'Tempo desperdiçado ao construir artesanalmente e remeter os feedbacks impressos ou isolados a cada educador.',
    icon: 'mail',
  },
];
---

<section class="pain" id="dores">
  <div class="pain__container">
    <div class="pain__header reveal">
      <span class="pain__badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
          <line x1="12" y1="9" x2="12" y2="13"></line>
          <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
        O Processo Defasado
      </span>
      <h2 class="pain__title">O custo escondido da consolidação manual</h2>
      <p class="pain__description">
        Procedimentos baseados em planilhas exigem exaustão humana ao mesmo tempo que produzem vulnerabilidade estratégica.
      </p>
    </div>

    <div class="pain__grid">
      {painPoints.map((point, index) => (
        <div class="pain__card glass reveal stagger" style={`transition-delay: ${index * 120}ms`}>
          <div class="pain__card-icon" aria-hidden="true">
            {point.icon === 'alert-triangle' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                <line x1="12" y1="9" x2="12" y2="13"></line>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
              </svg>
            )}
            {point.icon === 'lock' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
              </svg>
            )}
            {point.icon === 'mail' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
            )}
          </div>
          <h3 class="pain__card-title">{point.title}</h3>
          <p class="pain__card-desc">{point.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pain {
    position: relative;
    padding: 7rem 0;
  }

  .pain__container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .pain__header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 4rem;
  }

  .pain__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    background: rgba(191, 4, 4, 0.1);
    border: 1px solid rgba(191, 4, 4, 0.2);
    color: #ef4444;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .pain__title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: 1.25rem;
    letter-spacing: -1px;
  }

  .pain__description {
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .pain__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .pain__card {
    padding: 2.25rem;
    border-radius: 18px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border-color: rgba(191, 4, 4, 0.12) !important;
    cursor: pointer;
  }

  .pain__card:hover {
    border-color: rgba(191, 4, 4, 0.25) !important;
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(191, 4, 4, 0.1);
  }

  .pain__card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(191, 4, 4, 0.1);
    color: #ef4444;
    margin-bottom: 1.5rem;
  }

  .pain__card-title {
    font-size: 1.2rem;
    margin-bottom: 0.875rem;
    letter-spacing: -0.3px;
  }

  .pain__card-desc {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .pain__grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .pain {
      padding: 4rem 0;
    }
  }
</style>
