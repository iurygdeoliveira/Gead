---
/**
 * Navbar — Navegação principal com Glassmorphism
 * Fixa no topo, translúcida com blur
 */
---

<nav
  id="main-navbar"
  class="navbar"
  aria-label="Navegação principal"
>
  <div class="navbar__container">
    <a href="#inicio" class="navbar__brand" aria-label="GeAD - Ir ao início">
      <img src="/LOGO.jpeg" alt="Logo GeAD" class="navbar__logo" width="36" height="36" />
      <span class="navbar__name">GeAD</span>
    </a>

    <div class="navbar__links" role="navigation">
      <a href="#solucao" class="navbar__link">A Solução</a>
      <a href="#funcionalidades" class="navbar__link">Funcionalidades</a>
      <a href="#" class="btn btn-outline" id="btn-acesso">Acesso Restrito</a>
    </div>

    <!-- Mobile menu toggle -->
    <button
      id="mobile-menu-toggle"
      class="navbar__hamburger"
      aria-label="Abrir menu de navegação"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu" role="navigation" aria-label="Menu mobile">
    <a href="#solucao" class="mobile-menu__link">A Solução</a>
    <a href="#funcionalidades" class="mobile-menu__link">Funcionalidades</a>
    <a href="#" class="btn btn-outline mobile-menu__cta">Acesso Restrito</a>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 1.5rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .navbar__container {
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 5rem;
  }

  .navbar__brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    z-index: 10;
  }

  .navbar__logo {
    height: 36px;
    width: 36px;
    border-radius: 8px;
    object-fit: cover;
  }

  .navbar__name {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.5px;
  }

  .navbar__links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .navbar__link {
    font-weight: 500;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    cursor: pointer;
    position: relative;
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-highlight);
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 1px;
  }

  .navbar__link:hover {
    color: var(--color-text-primary);
  }

  .navbar__link:hover::after {
    width: 100%;
  }

  /* Scrolled state */
  :global(.navbar--scrolled) .navbar__container {
    /* enhanced upon scroll */
  }

  .navbar:global(.navbar--scrolled) {
    background: rgba(3, 15, 7, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border-glass);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
  }

  /* Hamburger (mobile only) */
  .navbar__hamburger {
    display: none;
    background: none;
    border: none;
    color: var(--color-text-primary);
    cursor: pointer;
    padding: 0.5rem;
    z-index: 10;
  }

  /* Mobile menu */
  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    background: rgba(3, 15, 7, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid var(--color-border-glass);
  }

  .mobile-menu__link {
    color: var(--color-text-secondary);
    font-weight: 500;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border-glass);
    cursor: pointer;
  }

  .mobile-menu__link:hover {
    color: var(--color-highlight);
  }

  .mobile-menu__cta {
    margin-top: 0.5rem;
    text-align: center;
  }

  @media (max-width: 768px) {
    .navbar__links {
      display: none;
    }

    .navbar__hamburger {
      display: flex;
    }

    :global(.mobile-menu--open) {
      display: flex !important;
    }
  }
</style>
